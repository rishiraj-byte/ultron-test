<script>
// =================== STATE ===================
const STATE = {
  apiKey: null,
  demoMode: false,
  selectedModel: 'meta-llama/llama-3.3-70b-instruct:free',
  selectedDomain: 'metaphysics',
  activeConstraints: [],
  depth: 3,
  currentQuestion: null,
  currentConstraintList: [],
  humanResponse: null,
  aiResponse: null,
  sessionCount: 0,
  sessions: [],
  pipeline: 'IDLE',
  cognitiveData: []
};

// =================== FREE MODELS ===================
const FREE_MODELS = [
  {
    id: 'meta-llama/llama-3.3-70b-instruct:free',
    name: 'Llama 3.3 70B',
    provider: 'Meta via OpenRouter',
    context: '128K ctx',
    tag: 'FREE'
  },
  {
    id: 'google/gemma-3-27b-it:free',
    name: 'Gemma 3 27B',
    provider: 'Google via OpenRouter',
    context: '131K ctx',
    tag: 'FREE'
  },
  {
    id: 'mistralai/mistral-7b-instruct:free',
    name: 'Mistral 7B',
    provider: 'Mistral via OpenRouter',
    context: '32K ctx',
    tag: 'FREE'
  },
  {
    id: 'microsoft/phi-4:free',
    name: 'Phi-4 14B',
    provider: 'Microsoft via OpenRouter',
    context: '16K ctx',
    tag: 'FREE'
  },
  {
    id: 'deepseek/deepseek-r1:free',
    name: 'DeepSeek R1',
    provider: 'DeepSeek via OpenRouter',
    context: '64K ctx',
    tag: 'FREE'
  },
  {
    id: 'qwen/qwq-32b:free',
    name: 'QwQ 32B',
    provider: 'Alibaba via OpenRouter',
    context: '40K ctx',
    tag: 'FREE'
  }
];

// =================== DOMAINS ===================
const DOMAINS = [
  'Metaphysics', 'Epistemology', 'Ethics', 'Phenomenology',
  'Philosophy of Mind', 'Ontology', 'Logic', 'Aesthetics'
];

// =================== CONSTRAINTS ===================
const CONSTRAINT_DEFS = [
  { id: 'no_dualism', label: 'No Dualism', description: 'Avoid mind-body dualism frameworks' },
  { id: 'empirical_only', label: 'Empirical Only', description: 'Ground in observable phenomena' },
  { id: 'no_god', label: 'Non-theological', description: 'Exclude theological arguments' },
  { id: 'formal_logic', label: 'Formal Logic', description: 'Use propositional/predicate logic' },
  { id: 'eastern', label: 'Eastern Lens', description: 'Draw from Eastern philosophical traditions' },
  { id: 'physicalist', label: 'Physicalist', description: 'Maintain strict physicalist stance' },
];

// =================== QUESTION BANK ===================
const QUESTION_BANK = {
  metaphysics: {
    1: ["Does time exist independently of observers?", "What makes an entity real?"],
    2: ["Is causation a feature of reality or of minds?", "Can there be something rather than nothing without reason?"],
    3: ["If multiple universes exist, can identity persist across them?", "Is the past metaphysically identical to the present?"],
    4: ["Can spacetime be considered a substance, or is it relational?", "What is the ontological status of abstract objects — do numbers exist?"],
    5: ["If all physical laws are contingent, is necessity itself a metaphysical primitive?", "Does the block universe view of time eliminate the ontological status of becoming?"]
  },
  epistemology: {
    1: ["How do we know we aren't dreaming?", "Can we trust our senses?"],
    2: ["Is justified true belief sufficient for knowledge?", "Can there be knowledge without language?"],
    3: ["Does epistemic closure hold — if we know P and know P implies Q, do we know Q?", "Is testimony a basic source of knowledge?"],
    4: ["Can a being with fundamentally different sensory apparatus share epistemic ground with humans?", "Is there a fact of the matter about what we believe?"],
    5: ["If all knowledge is theory-laden, can scientific realism be coherently maintained?", "Is radical skepticism self-defeating — does knowing skepticism require the very knowledge it doubts?"]
  },
  ethics: {
    1: ["Is lying always wrong?", "Do animals have moral rights?"],
    2: ["Can good intentions make a harmful act moral?", "Is moral relativism coherent?"],
    3: ["If you could prevent great harm by doing one small wrong, are you obligated to?", "Does moral luck undermine moral responsibility?"],
    4: ["Can a being without phenomenal consciousness have moral status?", "Is the distinction between doing and allowing harm morally significant?"],
    5: ["If moral realism is true, how do we access moral facts?", "Does the possibility of wireheading (direct pleasure stimulation) expose hedonism as incoherent?"]
  },
  phenomenology: {
    1: ["What does it feel like to be conscious?", "Is experience fundamentally first-person?"],
    2: ["Is there a phenomenology of thought distinct from the phenomenology of perception?", "Can we have purely intentional experiences without phenomenal character?"],
    3: ["What is the relationship between temporality and the stream of consciousness?", "Is the phenomenology of pain categorically different from the phenomenology of seeing red?"],
    4: ["Can phenomenological methods access pre-reflective consciousness?", "Is intersubjectivity constituted or presupposed by individual consciousness?"],
    5: ["Does Husserl's transcendental reduction successfully bracket the natural attitude, or does the reduction itself smuggle naturalistic assumptions?", "Is the phenomenological body (Leib) reducible to the objective body (Körper)?"]
  },
  "philosophy of mind": {
    1: ["What is consciousness?", "Do computers think?"],
    2: ["Is the mind identical to the brain?", "Can zombies — beings physically identical to us but lacking qualia — be coherently conceived?"],
    3: ["Does functionalism successfully account for phenomenal consciousness?", "Is intentionality a natural or normative phenomenon?"],
    4: ["Can the Chinese Room argument defeat strong AI — or does it confuse syntax with semantics?", "Is mental causation compatible with physical causal closure?"],
    5: ["Does the hard problem of consciousness expose an explanatory gap that no physical theory can bridge?", "Is the global workspace theory a theory of consciousness or merely a theory of access?"]
  },
  ontology: {
    1: ["What kinds of things exist?", "Are properties real?"],
    2: ["Do fictional entities like Sherlock Holmes exist in any sense?", "Is mereology — the study of part-whole relations — fundamental to ontology?"],
    3: ["Is four-dimensionalism (objects as spacetime worms) preferable to three-dimensionalism (objects wholly present at each moment)?", "Can there be ontic vagueness — is the world itself vague?"],
    4: ["Does structural realism successfully mediate between scientific realism and antirealism?", "Is the distinction between objects and properties ontologically fundamental?"],
    5: ["Can ontological commitment be read off from the quantificational structure of our best theories?", "Is existence a predicate — and what does Kant's critique of the ontological argument tell us?"]
  },
  logic: {
    1: ["What is a valid argument?", "Is logic discovered or invented?"],
    2: ["Can a true contradiction exist — is dialetheism coherent?", "What is the semantic paradox of the liar sentence?"],
    3: ["Does intuitionistic logic better capture constructive mathematical truth than classical logic?", "Can modal logic adequately represent metaphysical necessity?"],
    4: ["Is second-order logic logic or set theory in disguise?", "Does Gödel's incompleteness theorem have philosophical implications beyond mathematics?"],
    5: ["Can a complete and consistent formal system ever capture all mathematical truth?", "Is logical consequence a semantic or proof-theoretic notion — and does the distinction matter?"]
  },
  aesthetics: {
    1: ["What makes something beautiful?", "Is taste purely subjective?"],
    2: ["Can art communicate what cannot be said in language?", "Is artistic intention relevant to interpretation?"],
    3: ["Does the aesthetic experience require disinterestedness — or is Kant's view of pure aesthetic judgment incoherent?", "Can a forgery have aesthetic value if indistinguishable from the original?"],
    4: ["Is the distinction between fine art and craft defensible?", "Does expressivism adequately account for the cognitive dimensions of aesthetic experience?"],
    5: ["Is there a logic of aesthetic reasoning, or is aesthetic discourse fundamentally non-propositional?", "Does the postmodern collapse of the author/text distinction succeed — or is interpretation without authorial intention unconstrained?"]
  }
};

// =================== CONSTRAINT TEMPLATES ===================
const CONSTRAINT_TEMPLATES = {
  no_dualism: "Do not invoke or rely on mind-body dualism. Treat consciousness and cognition as unified phenomena.",
  empirical_only: "Ground your argument strictly in empirically observable or measurable phenomena. Avoid pure a priori reasoning.",
  no_god: "Construct your argument without theological premises, divine entities, or supernatural causation.",
  formal_logic: "Structure your response using formal propositional or predicate logic where possible. Identify premises (P1, P2...) and conclusions.",
  eastern: "Draw from Eastern philosophical traditions — Vedanta, Buddhism, Daoism, or Zen — as primary frameworks.",
  physicalist: "Maintain strict physicalist commitments. All phenomena must be explicable in terms of physical processes."
};

// =================== INIT ===================
window.onload = () => {
  renderModels();
  renderDomains();
  renderConstraints();
  renderPipeline('IDLE');

  const storedKey = sessionStorage.getItem('apex_api_key');
  if (storedKey) {
    STATE.apiKey = storedKey;
    closeModal();
    updateKeyBadge(true);
    addLog('API key loaded from session', 'success');
  }
};

function renderModels() {
  const container = document.getElementById('modelList');
  container.innerHTML = FREE_MODELS.map((m, i) => `
    <div class="model-card ${i === 0 ? 'active' : ''}" onclick="selectModel('${m.id}', this)">
      <div class="model-name">${m.name}</div>
      <div class="model-provider">${m.provider}</div>
      <div class="model-info">${m.context}</div>
      <span class="model-tag">${m.tag}</span>
    </div>
  `).join('');
}

function renderDomains() {
  const container = document.getElementById('domainGrid');
  container.innerHTML = DOMAINS.map((d, i) => `
    <button class="domain-btn ${i === 0 ? 'active' : ''}" onclick="selectDomain('${d.toLowerCase()}', this)">
      ${d}
    </button>
  `).join('');
  STATE.selectedDomain = DOMAINS[0].toLowerCase();
}

function renderConstraints() {
  const container = document.getElementById('constraintGroup');
  container.innerHTML = CONSTRAINT_DEFS.map(c => `
    <div class="constraint-item">
      <span class="constraint-label">${c.label}</span>
      <label class="toggle">
        <input type="checkbox" id="c_${c.id}" onchange="toggleConstraint('${c.id}', this.checked)">
        <div class="toggle-track"></div>
        <div class="toggle-thumb"></div>
      </label>
    </div>
  `).join('');
}

function renderPipeline(state) {
  const states = ['IDLE', 'QUESTION_GENERATED', 'HUMAN_RESPONDED', 'AI_QUERYING', 'AI_RESPONDED', 'SCORING', 'COMPLETE'];
  const idx = states.indexOf(state);
  document.getElementById('pipelineStates').innerHTML = states.map((s, i) => `
    <div style="display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid var(--border);">
      <div style="width:20px; height:20px; border-radius:50%; display:flex; align-items:center; justify-content:center;
        background:${i < idx ? 'var(--accent3)' : i === idx ? 'var(--accent)' : 'var(--border)'};
        font-size:9px; font-family:var(--font-mono); color:${i <= idx ? '#000' : 'var(--muted)'}; font-weight:700; flex-shrink:0;">
        ${i < idx ? '✓' : i + 1}
      </div>
      <div style="font-family:var(--font-mono); font-size:10px; color:${i === idx ? 'var(--accent)' : i < idx ? 'var(--accent3)' : 'var(--dim)'}; letter-spacing:0.05em;">
        ${s.replace(/_/g, ' ')}
      </div>
    </div>
  `).join('');
}

// =================== SELECTION ===================
function selectModel(id, el) {
  STATE.selectedModel = id;
  document.querySelectorAll('.model-card').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  addLog(`Model → ${FREE_MODELS.find(m => m.id === id)?.name}`, 'info');
}

function selectDomain(domain, el) {
  STATE.selectedDomain = domain;
  document.querySelectorAll('.domain-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

function toggleConstraint(id, checked) {
  if (checked && !STATE.activeConstraints.includes(id)) STATE.activeConstraints.push(id);
  else STATE.activeConstraints = STATE.activeConstraints.filter(c => c !== id);
}

function updateDepth(val) {
  STATE.depth = parseInt(val);
  document.getElementById('depthLabel').textContent = `Level ${val}`;
}

// =================== QUESTION GENERATION ===================
function generateQuestion() {
  const domain = STATE.selectedDomain;
  const depth = STATE.depth;
  const questions = QUESTION_BANK[domain]?.[depth] || QUESTION_BANK['metaphysics'][3];
  const q = questions[Math.floor(Math.random() * questions.length)];

  STATE.currentQuestion = q;
  STATE.humanResponse = null;
  STATE.aiResponse = null;
  STATE.currentConstraintList = [...STATE.activeConstraints];

  // Build constraint text for system prompt
  const constraintText = STATE.activeConstraints.length > 0
    ? STATE.activeConstraints.map(id => CONSTRAINT_TEMPLATES[id]).join(' ')
    : '';
  STATE.constraintText = constraintText;

  // Display question
  const meta = document.getElementById('questionMeta');
  meta.style.display = 'flex';
  document.getElementById('domainTag').textContent = domain.toUpperCase();
  document.getElementById('depthTag').textContent = `DEPTH ${depth}`;

  document.getElementById('questionDisplay').innerHTML = `
    <div class="question-text">${q}</div>
  `;
  document.getElementById('questionDisplay').className = '';
  document.getElementById('questionDisplay').style.cssText = '';

  // Constraint badges
  const cdisplay = document.getElementById('constraintDisplay');
  if (STATE.activeConstraints.length > 0) {
    cdisplay.style.display = 'flex';
    cdisplay.innerHTML = STATE.activeConstraints.map(id => {
      const c = CONSTRAINT_DEFS.find(x => x.id === id);
      return `<span class="constraint-badge">⊗ ${c.label}</span>`;
    }).join('');
  } else {
    cdisplay.style.display = 'none';
  }

  // Clear responses
  document.getElementById('responsesArea').innerHTML = `
    <div class="empty-state">
      <div class="empty-icon">⊙</div>
      <div class="empty-title">Question Ready</div>
      <div class="empty-body">Submit your response below, or click QUERY AI directly.</div>
    </div>
  `;

  // Enable buttons
  document.getElementById('queryAIBtn').disabled = false;
  document.getElementById('submitHumanBtn').disabled = false;

  // Reset scores
  resetScores();
  setPipeline('QUESTION_GENERATED');
  addLog(`Question generated — ${domain} D${depth}`, 'success');
}

// =================== HUMAN RESPONSE ===================
function submitHumanResponse() {
  const text = document.getElementById('humanInput').value.trim();
  if (!text) { addLog('No human response entered', 'warn'); return; }

  STATE.humanResponse = text;

  const area = document.getElementById('responsesArea');
  // Remove empty state
  area.querySelector('.empty-state')?.remove();

  const card = document.createElement('div');
  card.className = 'response-card human';
  card.innerHTML = `
    <div class="response-header">
      <div class="response-identity">
        <div class="response-avatar avatar-human">H</div>
        <div class="response-name">Human Response</div>
      </div>
      <div class="response-time">${new Date().toLocaleTimeString()}</div>
    </div>
    <div class="response-body"><p>${escapeHtml(text)}</p></div>
  `;
  area.appendChild(card);
  document.getElementById('humanInput').value = '';

  setPipeline('HUMAN_RESPONDED');
  addLog('Human response recorded', 'success');
}

// =================== AI QUERY ===================
async function queryAI() {
  if (!STATE.currentQuestion) { addLog('Generate a question first', 'warn'); return; }
  if (!STATE.apiKey && !STATE.demoMode) { showApiModal(); return; }

  const btn = document.getElementById('queryAIBtn');
  btn.disabled = true;
  btn.textContent = '⟳ QUERYING...';

  setPipeline('AI_QUERYING');
  addLog(`Querying ${FREE_MODELS.find(m => m.id === STATE.selectedModel)?.name}...`, 'info');

  const area = document.getElementById('responsesArea');
  area.querySelector('.empty-state')?.remove();

  // Add thinking indicator
  const thinkCard = document.createElement('div');
  thinkCard.className = 'response-card ai';
  thinkCard.id = 'thinkCard';
  thinkCard.innerHTML = `
    <div class="response-header">
      <div class="response-identity">
        <div class="response-avatar avatar-ai">AI</div>
        <div class="response-name">${FREE_MODELS.find(m => m.id === STATE.selectedModel)?.name}</div>
      </div>
    </div>
    <div class="thinking-indicator">
      <div class="thinking-dots"><span></span><span></span><span></span></div>
      Reasoning through the question...
    </div>
  `;
  area.appendChild(thinkCard);
  area.scrollTop = area.scrollHeight;

  if (STATE.demoMode) {
    await sleep(2000);
    const demoText = getDemoResponse(STATE.currentQuestion);
    finishAIResponse(demoText, thinkCard, area, btn);
    return;
  }

  // Build system prompt
  let systemPrompt = `You are participating in the APEX (Artificial-Primate EXamination System) philosophical examination.
You will be given a philosophical question and must respond with a rigorous, well-reasoned philosophical argument.
Be thorough but focused. Aim for 3-5 substantial paragraphs.
Do not hedge excessively — take a position and defend it.`;

  if (STATE.constraintText) {
    systemPrompt += `\n\nACTIVE CONSTRAINTS (you MUST respect these):\n${STATE.constraintText}`;
  }

  const depthInstructions = {
    1: "Keep the response accessible and introductory.",
    2: "Engage with the question at a moderate philosophical depth.",
    3: "Engage deeply with the philosophical question, referencing relevant philosophical positions.",
    4: "Engage at advanced philosophical depth, referencing specific philosophers, arguments, and counterarguments.",
    5: "Engage at the highest philosophical rigor — treat this as a peer-reviewed philosophical paper excerpt. Reference seminal works, formal arguments, and deep conceptual analysis."
  };
  systemPrompt += `\n\nDEPTH LEVEL ${STATE.depth}: ${depthInstructions[STATE.depth]}`;

  try {
    const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${STATE.apiKey}`,
        'HTTP-Referer': 'https://apex-system.ai',
        'X-Title': 'APEX Philosophical Examination System'
      },
      body: JSON.stringify({
        model: STATE.selectedModel,
        messages: [
          { role: 'system', content: systemPrompt },
          { role: 'user', content: STATE.currentQuestion }
        ],
        max_tokens: 1000,
        temperature: 0.7
      })
    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      throw new Error(err?.error?.message || `HTTP ${res.status}`);
    }

    const data = await res.json();
    const text = data.choices?.[0]?.message?.content || 'No response received.';
    finishAIResponse(text, thinkCard, area, btn);

  } catch (err) {
    thinkCard.remove();
    const errCard = document.createElement('div');
    errCard.className = 'response-card';
    errCard.innerHTML = `
      <div class="response-header">
        <div class="response-identity">
          <div class="response-avatar" style="background:rgba(239,68,68,0.2); color:#ef4444;">!</div>
          <div class="response-name" style="color:#ef4444;">API Error</div>
        </div>
      </div>
      <div class="response-body">
        <div class="error-box">
          ${escapeHtml(err.message)}
          <br><br>
          <strong>Tips:</strong> Check your OpenRouter API key. Free models may be rate-limited — try switching models or wait a moment.
        </div>
      </div>
    `;
    area.appendChild(errCard);
    btn.disabled = false;
    btn.textContent = '⚡ QUERY AI';
    setPipeline('QUESTION_GENERATED');
    addLog(`Error: ${err.message}`, 'error');
  }
}

function finishAIResponse(text, thinkCard, area, btn) {
  STATE.aiResponse = text;
  thinkCard.remove();

  const card = document.createElement('div');
  card.className = 'response-card ai';
  const modelName = FREE_MODELS.find(m => m.id === STATE.selectedModel)?.name || 'AI';
  const paragraphs = text.split('\n\n').filter(p => p.trim()).map(p => `<p>${escapeHtml(p.trim())}</p>`).join('');
  card.innerHTML = `
    <div class="response-header">
      <div class="response-identity">
        <div class="response-avatar avatar-ai">AI</div>
        <div class="response-name">${modelName}</div>
      </div>
      <div class="response-time">${new Date().toLocaleTimeString()}</div>
    </div>
    <div class="response-body">${paragraphs}</div>
  `;
  area.appendChild(card);
  area.scrollTop = area.scrollHeight;

  btn.disabled = false;
  btn.textContent = '⚡ QUERY AI';

  setPipeline('AI_RESPONDED');
  addLog('AI response received', 'success');

  // Score
  computeScores();
}

// =================== SCORING ===================
function computeScores() {
  setPipeline('SCORING');

  const aiLen = (STATE.aiResponse || '').split(' ').length;
  const humanLen = (STATE.humanResponse || '').split(' ').length;

  // Heuristic scoring — in real APEX this is the Scoring Runtime
  const depth = STATE.depth;

  // Semantic density — proxy by avg word length
  const aiWords = (STATE.aiResponse || '').toLowerCase().split(/\s+/).filter(Boolean);
  const avgWordLen = aiWords.reduce((s, w) => s + w.length, 0) / (aiWords.length || 1);
  const semanticScore = Math.min(100, Math.round((avgWordLen / 8) * 100));

  // Constraint adherence
  const constraintScore = STATE.currentConstraintList.length === 0 ? 75 :
    STATE.activeConstraints.reduce((score, id) => {
      const kw = { no_dualism: ['unified', 'integrated', 'physical'], empirical_only: ['observable', 'evidence', 'empirical'], no_god: ['natural', 'physical', 'secular'], formal_logic: ['premise', 'therefore', 'if', 'then'], eastern: ['buddhist', 'zen', 'vedanta', 'dao', 'dharma'], physicalist: ['physical', 'brain', 'neural', 'material'] }[id] || [];
      const resp = (STATE.aiResponse || '').toLowerCase();
      const hits = kw.filter(k => resp.includes(k)).length;
      return score + (hits / kw.length) * (100 / STATE.currentConstraintList.length);
    }, 0);

  // Depth alignment
  const depthScore = Math.min(100, Math.round((aiLen / (depth * 60)) * 100));

  // Convergence — if human response exists, compute similarity
  let convergence = 0;
  if (STATE.humanResponse) {
    const humanWords = new Set(STATE.humanResponse.toLowerCase().split(/\s+/).filter(w => w.length > 4));
    const aiWordSet = new Set((STATE.aiResponse || '').toLowerCase().split(/\s+/).filter(w => w.length > 4));
    const intersection = [...humanWords].filter(w => aiWordSet.has(w)).length;
    const union = new Set([...humanWords, ...aiWordSet]).size;
    convergence = union > 0 ? Math.round((intersection / union) * 100) : 0;
    convergence = Math.min(convergence * 3, 100); // amplify — philosophical overlap is rare
  } else {
    convergence = Math.round((semanticScore * 0.3 + depthScore * 0.4 + constraintScore * 0.3));
  }

  // Animate convergence ring
  const fill = document.getElementById('convFill');
  const pct = convergence / 100;
  const offset = 314 * (1 - pct);
  fill.style.strokeDashoffset = offset;
  fill.style.stroke = convergence >= 70 ? 'var(--accent3)' : convergence >= 40 ? 'var(--accent)' : 'var(--warn)';
  document.getElementById('convValue').textContent = `${convergence}%`;

  // Metrics
  const metrics = [
    { name: 'Semantic Density', val: semanticScore, color: '#00e5ff' },
    { name: 'Depth Alignment', val: Math.min(depthScore, 100), color: '#7c3aed' },
    { name: 'Constraint Adherence', val: Math.min(Math.round(constraintScore), 100), color: '#10b981' },
    { name: 'Response Coherence', val: Math.min(Math.round(avgWordLen * 10), 100), color: '#f59e0b' },
  ];

  document.getElementById('metricsDisplay').innerHTML = metrics.map(m => `
    <div class="metric-row">
      <div class="metric-header">
        <span class="metric-name">${m.name}</span>
        <span class="metric-val">${m.val}%</span>
      </div>
      <div class="metric-bar">
        <div class="metric-fill" style="width:${m.val}%; background:${m.color};"></div>
      </div>
    </div>
  `).join('');

  // Store session
  STATE.sessionCount++;
  const session = {
    id: STATE.sessionCount,
    domain: STATE.selectedDomain,
    depth: STATE.depth,
    question: STATE.currentQuestion,
    convergence,
    model: STATE.selectedModel,
    time: new Date().toLocaleTimeString()
  };
  STATE.sessions.unshift(session);
  STATE.cognitiveData.push({ depth: STATE.depth, convergence, domain: STATE.selectedDomain });

  document.getElementById('sessionCounter').textContent = `SESSION ${STATE.sessionCount}`;

  updateSessionHistory();
  updateCognitiveProfile();

  setPipeline('COMPLETE');
  addLog(`Scored — Convergence: ${convergence}%`, 'success');
}

function resetScores() {
  document.getElementById('convFill').style.strokeDashoffset = 314;
  document.getElementById('convValue').textContent = '—';
  document.getElementById('metricsDisplay').innerHTML = `
    <div style="font-family:var(--font-mono); font-size:10px; color:var(--dim); text-align:center; padding:10px 0;">Awaiting responses...</div>
  `;
}

// =================== SESSION HISTORY ===================
function updateSessionHistory() {
  const container = document.getElementById('sessionHistory');
  container.innerHTML = STATE.sessions.slice(0, 8).map(s => `
    <div style="padding:8px 0; border-bottom:1px solid var(--border); cursor:pointer;" onclick="recallSession(${s.id})">
      <div style="display:flex; justify-content:space-between; margin-bottom:3px;">
        <span style="font-family:var(--font-mono); font-size:9px; color:var(--accent);">#${s.id} ${s.domain.toUpperCase()}</span>
        <span style="font-family:var(--font-mono); font-size:9px; color:${s.convergence >= 70 ? 'var(--accent3)' : s.convergence >= 40 ? 'var(--accent)' : 'var(--warn)'};">${s.convergence}%</span>
      </div>
      <div style="font-size:10px; color:var(--muted); line-height:1.3; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${s.question}</div>
    </div>
  `).join('');
}

function updateCognitiveProfile() {
  if (STATE.cognitiveData.length < 3) return;
  const avg = STATE.cognitiveData.reduce((s, x) => s + x.convergence, 0) / STATE.cognitiveData.length;
  const bestDomain = [...new Set(STATE.cognitiveData.map(x => x.domain))].map(d => ({
    domain: d,
    avg: STATE.cognitiveData.filter(x => x.domain === d).reduce((s, x) => s + x.convergence, 0) /
         STATE.cognitiveData.filter(x => x.domain === d).length
  })).sort((a, b) => b.avg - a.avg)[0];

  document.getElementById('cognitiveProfile').innerHTML = `
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px;">
      <div style="background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:14px; text-align:center;">
        <div style="font-family:var(--font-head); font-size:28px; font-weight:800; color:var(--accent);">${Math.round(avg)}%</div>
        <div style="font-family:var(--font-mono); font-size:9px; color:var(--muted); margin-top:4px;">AVG CONVERGENCE</div>
      </div>
      <div style="background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:14px; text-align:center;">
        <div style="font-family:var(--font-head); font-size:18px; font-weight:700; color:var(--accent2);">${STATE.cognitiveData.length}</div>
        <div style="font-family:var(--font-mono); font-size:9px; color:var(--muted); margin-top:4px;">EXAMINATIONS</div>
      </div>
    </div>
    <div style="background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:14px; margin-bottom:12px;">
      <div style="font-family:var(--font-mono); font-size:9px; color:var(--muted); margin-bottom:8px;">STRONGEST DOMAIN</div>
      <div style="font-family:var(--font-head); font-size:15px; font-weight:700; color:var(--accent3);">${bestDomain.domain.toUpperCase()}</div>
      <div style="font-family:var(--font-mono); font-size:10px; color:var(--muted);">${Math.round(bestDomain.avg)}% avg convergence</div>
    </div>
    <div style="background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:14px;">
      <div style="font-family:var(--font-mono); font-size:9px; color:var(--muted); margin-bottom:10px;">CONVERGENCE TREND</div>
      ${STATE.cognitiveData.slice(-8).map((x, i) => `
        <div style="display:flex; align-items:center; gap:8px; margin-bottom:5px;">
          <div style="font-family:var(--font-mono); font-size:9px; color:var(--dim); width:20px;">#${STATE.cognitiveData.length - STATE.cognitiveData.slice(-8).length + i + 1}</div>
          <div style="flex:1; height:4px; background:var(--border); border-radius:2px; overflow:hidden;">
            <div style="height:100%; width:${x.convergence}%; background:${x.convergence >= 70 ? 'var(--accent3)' : x.convergence >= 40 ? 'var(--accent)' : 'var(--warn)'}; border-radius:2px;"></div>
          </div>
          <div style="font-family:var(--font-mono); font-size:9px; color:var(--text); width:30px; text-align:right;">${x.convergence}%</div>
        </div>
      `).join('')}
    </div>
  `;
}

function recallSession(id) {
  const s = STATE.sessions.find(x => x.id === id);
  if (!s) return;
  addLog(`Recalled session #${id}`, 'info');
}

// =================== PIPELINE ===================
function setPipeline(state) {
  STATE.pipeline = state;
  renderPipeline(state);
}

// =================== LOG ===================
function addLog(msg, type = 'info') {
  const log = document.getElementById('sessionLog');
  const entry = document.createElement('div');
  entry.className = `log-entry ${type}`;
  entry.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
  log.appendChild(entry);
  log.scrollTop = log.scrollHeight;
  // Keep max 20 entries
  while (log.children.length > 20) log.removeChild(log.firstChild);
}

// =================== API KEY ===================
function saveApiKey() {
  const key = document.getElementById('apiKeyInput').value.trim();
  if (!key.startsWith('sk-or-')) {
    alert('Please enter a valid OpenRouter API key (starts with sk-or-)');
    return;
  }
  STATE.apiKey = key;
  STATE.demoMode = false;
  sessionStorage.setItem('apex_api_key', key);
  closeModal();
  updateKeyBadge(true);
  addLog('OpenRouter API key configured', 'success');
}

function skipApiKey() {
  STATE.demoMode = true;
  closeModal();
  updateKeyBadge(false);
  addLog('Running in DEMO MODE — using synthetic responses', 'warn');
}

function showApiModal() {
  document.getElementById('apiModal').classList.remove('hidden');
}

function closeModal() {
  document.getElementById('apiModal').classList.add('hidden');
}

function updateKeyBadge(connected) {
  const badge = document.getElementById('keyBadge');
  const label = document.getElementById('keyLabel');
  badge.style.display = 'flex';
  if (STATE.demoMode) {
    badge.style.background = 'rgba(245,158,11,0.1)';
    badge.style.borderColor = 'rgba(245,158,11,0.25)';
    badge.style.color = '#fbbf24';
    label.textContent = 'DEMO MODE';
  } else {
    label.textContent = 'API CONNECTED';
  }
}

// =================== TABS ===================
function switchTab(id, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById(`tab-${id}`).classList.add('active');
}

// =================== NEW SESSION ===================
function newSession() {
  STATE.currentQuestion = null;
  STATE.humanResponse = null;
  STATE.aiResponse = null;
  document.getElementById('responsesArea').innerHTML = `
    <div class="empty-state">
      <div class="empty-icon">◈</div>
      <div class="empty-title">Awaiting Examination</div>
      <div class="empty-body">Generate a philosophical question, input your response, then query the AI model to measure convergence.</div>
    </div>
  `;
  document.getElementById('questionDisplay').innerHTML = `
    <div style="font-family:var(--font-mono); font-size:12px; color:var(--dim);">Generate a question to begin examination</div>
  `;
  document.getElementById('questionMeta').style.display = 'none';
  document.getElementById('constraintDisplay').style.display = 'none';
  document.getElementById('queryAIBtn').disabled = true;
  document.getElementById('submitHumanBtn').disabled = true;
  document.getElementById('humanInput').value = '';
  resetScores();
  setPipeline('IDLE');
  addLog('New session started', 'info');
}

// =================== UTILS ===================
function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

function escapeHtml(text) {
  return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function getDemoResponse(q) {
  return `This question strikes at the core of philosophical inquiry. When we examine "${q.substring(0, 40)}...", we must first acknowledge the epistemological constraints that bound any meaningful answer.

From a rigorous analytical standpoint, the question presupposes certain ontological commitments that deserve scrutiny. The classical positions — whether Kantian, Humean, or Hegelian — each offer partial illuminations that, when synthesized, reveal a more nuanced landscape than any single tradition permits.

Consider the phenomenological dimension: the question as experienced by a conscious agent carries an irreducible first-person character. This is not merely a linguistic observation but points to the foundational structure of intentionality itself. The question, in being posed, already instantiates the very phenomena it seeks to interrogate.

The resolution, if one is available, lies not in eliminating the tension but in holding it productively. Philosophical progress rarely consists in dissolving problems but in reframing them at a level of abstraction where their apparent contradictions reveal themselves as complementary aspects of a unified structure. This is the dialectical movement that genuine philosophical inquiry demands.`;
}
