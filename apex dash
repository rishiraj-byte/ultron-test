<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APEX — Artificial-Primate EXamination System</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;1,9..40,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #05070d;
    --surface: #0b0f1a;
    --surface2: #111827;
    --border: #1e2d45;
    --accent: #00e5ff;
    --accent2: #7c3aed;
    --accent3: #10b981;
    --warn: #f59e0b;
    --danger: #ef4444;
    --text: #e2e8f0;
    --muted: #64748b;
    --dim: #334155;
    --font-head: 'Syne', sans-serif;
    --font-mono: 'Space Mono', monospace;
    --font-body: 'DM Sans', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* GRID NOISE BACKGROUND */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.025) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* HEADER */
  header {
    position: relative;
    z-index: 10;
    padding: 20px 32px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(5,7,13,0.9);
    backdrop-filter: blur(12px);
  }

  .logo {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .logo-text {
    font-family: var(--font-head);
    font-size: 22px;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--accent);
    text-shadow: 0 0 20px rgba(0,229,255,0.4);
  }

  .logo-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  .header-status {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .status-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    padding: 5px 12px;
    border: 1px solid var(--border);
    border-radius: 20px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent3);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* MAIN LAYOUT */
  .main {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 280px 1fr 320px;
    height: calc(100vh - 65px);
  }

  /* LEFT SIDEBAR */
  .sidebar-left {
    border-right: 1px solid var(--border);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    overflow-y: auto;
    background: rgba(11,15,26,0.6);
  }

  .sidebar-section {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }

  /* MODEL SELECTOR */
  .model-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 12px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .model-card:hover {
    border-color: var(--accent);
    background: rgba(0,229,255,0.05);
  }

  .model-card.active {
    border-color: var(--accent);
    background: rgba(0,229,255,0.08);
    box-shadow: 0 0 12px rgba(0,229,255,0.1);
  }

  .model-name {
    font-family: var(--font-head);
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
  }

  .model-card.active .model-name { color: var(--accent); }

  .model-info {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--muted);
  }

  .model-tag {
    display: inline-block;
    padding: 2px 6px;
    background: rgba(16,185,129,0.15);
    border: 1px solid rgba(16,185,129,0.3);
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 8px;
    color: var(--accent3);
    margin-top: 4px;
    align-self: flex-start;
  }

  /* CONSTRAINT CONTROLS */
  .constraint-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .constraint-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .constraint-label {
    font-size: 11px;
    color: var(--muted);
    font-family: var(--font-body);
  }

  .toggle {
    position: relative;
    width: 32px;
    height: 16px;
    cursor: pointer;
  }

  .toggle input { display: none; }

  .toggle-track {
    position: absolute;
    inset: 0;
    background: var(--dim);
    border-radius: 8px;
    transition: 0.2s;
  }

  .toggle input:checked ~ .toggle-track { background: var(--accent2); }

  .toggle-thumb {
    position: absolute;
    left: 2px;
    top: 2px;
    width: 12px;
    height: 12px;
    background: white;
    border-radius: 50%;
    transition: 0.2s;
  }

  .toggle input:checked ~ .toggle-thumb { left: 18px; }

  .slider-control {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .slider-header {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
  }

  input[type="range"] {
    -webkit-appearance: none;
    width: 100%;
    height: 3px;
    background: var(--dim);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }

  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px;
    height: 12px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 8px rgba(0,229,255,0.5);
  }

  /* QUESTION DOMAIN PICKER */
  .domain-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }

  .domain-btn {
    padding: 7px 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .domain-btn:hover { border-color: var(--accent2); color: var(--text); }
  .domain-btn.active {
    border-color: var(--accent2);
    background: rgba(124,58,237,0.15);
    color: #a78bfa;
  }

  /* CENTER PANEL */
  .center-panel {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .panel-header {
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(11,15,26,0.4);
  }

  .panel-title {
    font-family: var(--font-head);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--text);
  }

  .panel-actions {
    display: flex;
    gap: 8px;
  }

  .btn {
    padding: 8px 16px;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
    box-shadow: 0 0 16px rgba(0,229,255,0.3);
  }

  .btn-primary:hover {
    box-shadow: 0 0 24px rgba(0,229,255,0.5);
    transform: translateY(-1px);
  }

  .btn-primary:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .btn-ghost {
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--border);
  }

  .btn-ghost:hover { border-color: var(--accent2); color: var(--text); }

  .btn-accent2 {
    background: rgba(124,58,237,0.2);
    color: #a78bfa;
    border: 1px solid rgba(124,58,237,0.3);
  }

  .btn-accent2:hover { background: rgba(124,58,237,0.35); }

  /* QUESTION DISPLAY */
  .question-area {
    padding: 24px;
    border-bottom: 1px solid var(--border);
    background: rgba(0,229,255,0.02);
    min-height: 120px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .question-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .meta-tag {
    padding: 3px 8px;
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .meta-domain { background: rgba(124,58,237,0.15); color: #a78bfa; border: 1px solid rgba(124,58,237,0.25); }
  .meta-depth { background: rgba(245,158,11,0.1); color: #fbbf24; border: 1px solid rgba(245,158,11,0.2); }
  .meta-constraint { background: rgba(16,185,129,0.1); color: #34d399; border: 1px solid rgba(16,185,129,0.2); }

  .question-text {
    font-family: var(--font-head);
    font-size: 16px;
    font-weight: 600;
    line-height: 1.5;
    color: var(--text);
  }

  .constraint-display {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .constraint-badge {
    padding: 4px 10px;
    background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.2);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 9px;
    color: #fca5a5;
    letter-spacing: 0.03em;
  }

  /* RESPONSES AREA */
  .responses-area {
    flex: 1;
    overflow-y: auto;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .response-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .response-card.human { border-color: rgba(124,58,237,0.3); }
  .response-card.ai { border-color: rgba(0,229,255,0.2); }

  .response-header {
    padding: 10px 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    background: rgba(255,255,255,0.02);
  }

  .response-identity {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .response-avatar {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    font-family: var(--font-mono);
  }

  .avatar-human { background: rgba(124,58,237,0.3); color: #a78bfa; }
  .avatar-ai { background: rgba(0,229,255,0.15); color: var(--accent); }

  .response-name {
    font-family: var(--font-head);
    font-size: 12px;
    font-weight: 700;
    color: var(--text);
  }

  .response-time {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
  }

  .response-body {
    padding: 14px;
    font-size: 13px;
    line-height: 1.65;
    color: #cbd5e1;
  }

  .response-body p { margin-bottom: 10px; }
  .response-body p:last-child { margin-bottom: 0; }

  .thinking-indicator {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .thinking-dots span {
    display: inline-block;
    width: 5px;
    height: 5px;
    background: var(--accent);
    border-radius: 50%;
    animation: bounce 1s infinite;
    margin: 0 2px;
  }

  .thinking-dots span:nth-child(2) { animation-delay: 0.15s; }
  .thinking-dots span:nth-child(3) { animation-delay: 0.3s; }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); opacity: 0.4; }
    50% { transform: translateY(-5px); opacity: 1; }
  }

  /* HUMAN INPUT */
  .human-input-area {
    padding: 16px 24px;
    border-top: 1px solid var(--border);
    background: rgba(11,15,26,0.8);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .input-row {
    display: flex;
    gap: 10px;
    align-items: flex-end;
  }

  textarea {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 14px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.5;
    resize: none;
    min-height: 60px;
    max-height: 150px;
    outline: none;
    transition: border-color 0.2s;
  }

  textarea:focus { border-color: var(--accent2); }
  textarea::placeholder { color: var(--muted); }

  /* RIGHT SIDEBAR - SCORING */
  .sidebar-right {
    border-left: 1px solid var(--border);
    overflow-y: auto;
    background: rgba(11,15,26,0.6);
  }

  .score-section {
    padding: 16px;
    border-bottom: 1px solid var(--border);
  }

  .score-title {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  /* CONVERGENCE METER */
  .convergence-display {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 16px 0;
  }

  .conv-ring {
    position: relative;
    width: 120px;
    height: 120px;
  }

  .conv-ring svg {
    transform: rotate(-90deg);
  }

  .conv-track {
    fill: none;
    stroke: var(--border);
    stroke-width: 8;
  }

  .conv-fill {
    fill: none;
    stroke: var(--accent);
    stroke-width: 8;
    stroke-linecap: round;
    stroke-dasharray: 314;
    stroke-dashoffset: 314;
    transition: stroke-dashoffset 1s ease;
    filter: drop-shadow(0 0 6px rgba(0,229,255,0.5));
  }

  .conv-center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .conv-value {
    font-family: var(--font-head);
    font-size: 26px;
    font-weight: 800;
    color: var(--accent);
  }

  .conv-label {
    font-family: var(--font-mono);
    font-size: 8px;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  /* METRIC BARS */
  .metric-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 10px;
  }

  .metric-header {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
  }

  .metric-name { color: var(--muted); }
  .metric-val { color: var(--text); }

  .metric-bar {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .metric-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.8s ease;
  }

  /* SESSION LOG */
  .session-log {
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .log-entry {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    padding: 5px 8px;
    border-left: 2px solid var(--border);
    line-height: 1.4;
  }

  .log-entry.info { border-color: var(--accent); color: #94a3b8; }
  .log-entry.success { border-color: var(--accent3); color: #6ee7b7; }
  .log-entry.warn { border-color: var(--warn); color: #fcd34d; }
  .log-entry.error { border-color: var(--danger); color: #fca5a5; }

  /* API KEY MODAL */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(6px);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-overlay.hidden { display: none; }

  .modal {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    max-width: 520px;
    width: 90%;
    box-shadow: 0 0 60px rgba(0,229,255,0.1);
  }

  .modal-title {
    font-family: var(--font-head);
    font-size: 20px;
    font-weight: 800;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .modal-desc {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .modal-desc a { color: var(--accent); text-decoration: none; }
  .modal-desc a:hover { text-decoration: underline; }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 16px;
  }

  .input-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--muted);
    text-transform: uppercase;
  }

  input[type="text"], input[type="password"] {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 14px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    outline: none;
    width: 100%;
    transition: border-color 0.2s;
  }

  input[type="text"]:focus, input[type="password"]:focus {
    border-color: var(--accent);
  }

  .modal-note {
    font-size: 11px;
    color: var(--muted);
    margin-top: 12px;
    padding: 10px 12px;
    background: rgba(245,158,11,0.08);
    border: 1px solid rgba(245,158,11,0.15);
    border-radius: 6px;
  }

  /* EMPTY STATE */
  .empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: var(--muted);
    padding: 40px;
    text-align: center;
  }

  .empty-icon {
    font-size: 40px;
    opacity: 0.3;
  }

  .empty-title {
    font-family: var(--font-head);
    font-size: 15px;
    font-weight: 700;
    color: var(--dim);
  }

  .empty-body {
    font-size: 12px;
    max-width: 280px;
    line-height: 1.5;
  }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--dim); border-radius: 2px; }

  /* SUBSYSTEM TABS */
  .subsystem-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
    padding: 0 24px;
    background: rgba(5,7,13,0.6);
  }

  .tab {
    padding: 10px 16px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: all 0.15s;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
  }

  .tab.active { color: var(--accent); border-bottom-color: var(--accent); }
  .tab:hover:not(.active) { color: var(--text); }

  .tab-content { display: none; }
  .tab-content.active { display: flex; flex-direction: column; flex: 1; overflow: hidden; }

  /* API KEY stored notice */
  .key-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--accent3);
    padding: 4px 10px;
    background: rgba(16,185,129,0.1);
    border: 1px solid rgba(16,185,129,0.25);
    border-radius: 12px;
    cursor: pointer;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .main { grid-template-columns: 1fr; }
    .sidebar-left, .sidebar-right { display: none; }
  }

  /* Error */
  .error-box {
    padding: 12px 14px;
    background: rgba(239,68,68,0.08);
    border: 1px solid rgba(239,68,68,0.2);
    border-radius: 6px;
    font-size: 12px;
    color: #fca5a5;
    line-height: 1.5;
  }

  .model-provider {
    font-size: 8px;
    color: var(--dim);
